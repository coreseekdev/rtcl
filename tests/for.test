# Tests for for loop - extracted from jimtcl for.test
source [file dirname [info script]]/rtcl_test.tcl

puts "Testing for loop..."

catch {unset a i}

test for-1.1 {basic for loop} {
    set a {}
    for {set i 1} {$i<6} {set i [expr $i+1]} {
        set a [concat $a $i]
    }
    set a
} {1 2 3 4 5}

test for-1.2 {for loop with continue} {
    set a {}
    for {set i 1} {$i<6} {set i [expr $i+1]} {
        if {$i==4} continue
        set a [concat $a $i]
    }
    set a
} {1 2 3 5}

test for-1.3 {for loop with break} {
    set a {}
    for {set i 1} {$i<6} {set i [expr $i+1]} {
        if {$i==4} break
        set a [concat $a $i]
    }
    set a
} {1 2 3}

test for-1.4 {for with wrong args} {
    catch {for 1 2 3} msg
} {1}

test for-1.5 {for loop empty body} {
    set a {xyz}
    for {set i 1} {$i<6} {set i [expr $i+1]} {}
    set a
} {xyz}

test for-1.6 {for loop break in next} {
    set a {}
    for {set i 1} {$i<6} {set i [expr $i+1]; if {$i==4} break} {
        set a [concat $a $i]
    }
    set a
} {1 2 3}

testreport
